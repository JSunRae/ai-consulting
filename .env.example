# Local automation secrets for social-content workflows.
# Copy to .env for local use. Do not commit real values.

# Core LLM drafting
OPENAI_API_KEY=INSERT_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.4

# Social workflow behavior
SOCIAL_TIMEZONE=Europe/Berlin
SOCIAL_APPROVAL_MODE=manual
SOCIAL_AUTO_POST_ENABLED=false
SOCIAL_ARCHIVE_PATH=assets/data/social-posts.json
SOCIAL_GUIDANCE_PATH=assets/data/social-guidance.json
SOCIAL_CHANNELS_PATH=assets/data/social-channels.example.json

# News enrichment
NEWS_API_KEY=INSERT_OPTIONAL_NEWS_API_KEY

# Posting route
# Prefer a broker such as Buffer for LinkedIn personal-profile publishing.
BUFFER_ACCESS_TOKEN=INSERT_BUFFER_ACCESS_TOKEN
BUFFER_ORGANIZATION_ID=INSERT_OPTIONAL_BUFFER_ORGANIZATION_ID
BUFFER_LINKEDIN_CHANNEL_ID=INSERT_OPTIONAL_BUFFER_LINKEDIN_CHANNEL_ID
BUFFER_X_CHANNEL_ID=INSERT_OPTIONAL_BUFFER_X_CHANNEL_ID
X_API_KEY=INSERT_X_API_KEY
X_API_SECRET=INSERT_X_API_SECRET
X_ACCESS_TOKEN=INSERT_X_ACCESS_TOKEN
X_ACCESS_TOKEN_SECRET=INSERT_X_ACCESS_TOKEN_SECRET
LINKEDIN_ACCESS_TOKEN=INSERT_OPTIONAL_LINKEDIN_ACCESS_TOKEN

# Notifications / approvals
SOCIAL_APPROVAL_WEBHOOK_URL=INSERT_OPTIONAL_APPROVAL_WEBHOOK

# Voice intake scaffolding
VOICE_WEBHOOK_SECRET=INSERT_OPTIONAL_VOICE_WEBHOOK_SECRET
VOICE_AGENT_MODEL=gpt-realtime-1.5
VOICE_AGENT_VOICE=cedar
VOICE_OPERATOR_SECRET=INSERT_SEPARATE_OPERATOR_SECRET
VOICE_SUMMARY_WEBHOOK_URL=INSERT_OPTIONAL_SUMMARY_WEBHOOK
VOICE_SUMMARY_ENCRYPTION_KEY=INSERT_BASE64URL_OR_64_CHAR_HEX_KEY
VOICE_SUMMARY_RETENTION_DAYS=30
VOICE_SUMMARY_STORE_NAME=voice-intake-summaries
# Optional local-only override for direct Node testing outside `netlify dev`
# VOICE_SUMMARY_STORE_DRIVER=file
# VOICE_SUMMARY_LOCAL_PATH=data/voice-summary-store
OPENAI_PROJECT_ID=INSERT_OPENAI_PROJECT_ID_FOR_SIP
OPENAI_WEBHOOK_SECRET=INSERT_OPTIONAL_OPENAI_WEBHOOK_SECRET
TWILIO_ACCOUNT_SID=INSERT_OPTIONAL_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=INSERT_OPTIONAL_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=INSERT_OPTIONAL_TWILIO_GERMAN_NUMBER
TWILIO_SIP_TRUNK_SID=INSERT_OPTIONAL_TWILIO_SIP_TRUNK_SID
SUMMARY_TO_EMAIL=Jason_C_Rae@Outlook.com
SMTP_HOST=INSERT_OPTIONAL_SMTP_HOST
SMTP_USER=INSERT_OPTIONAL_SMTP_USER
SMTP_PASS=INSERT_OPTIONAL_SMTP_PASS
