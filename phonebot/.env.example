TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+441234567890
OPENAI_API_KEY=your_openai_api_key
PUBLIC_URL=https://<your-public-hostname>   # used to form the websocket URL for Twilio Media Streams
PORT=3000
PHONEBOT_ALLOW_INSECURE_LOCAL=false

# Notes:
# - Public URL must be reachable by Twilio (use ngrok or deploy to a public host)
# - Keep keys secret; do NOT commit real credentials
